{
  "name": "balatro-saves-sync",
  "type": "module",
  "version": "0.3.0",
  "description": "CLI tool to automatically sync Balatro saves between local and iCloud.",
  "license": "MIT",
  "bin": {
    "balatro-saves-sync": "./dist/balatro-saves-sync"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile dist/balatro-saves-sync",
    "build:all": "bash scripts/build-all.sh",
    "dev": "bun run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "manifest": "bun run scripts/generate-manifest.ts",
    "release": "bash scripts/release.sh",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.1",
    "auto-launch": "^5.0.6",
    "cac": "^6.7.14",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "bumpp": "^10.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
